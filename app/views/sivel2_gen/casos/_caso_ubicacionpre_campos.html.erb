<%= turbo_frame_tag "caso_ubicacionpre_#{f.index}" do %>
<div class='control-group nested-fields'>
  <div class="controls">
    <%= f.input :id, as: :hidden %>
    <div class="row">
      <div class="col-md-6">
        <%= f.input :ubicacionpre,
          collection: Msip::ModeloHelper.opciones_tabla_basica(
            Msip::Ubicacionpre, f, :ubicacionpre
          ),
          label_method: :nombre,
          value_method: :id %>
      </div>
    </div>

    <%= f.submit "Eliminar", 
      formaction: eliminar_caso_ubicacionpre_path(
        id: f.object ? f.object.id : nil, index: f.index
      ),
      formmethod: :delete, 
      formnovalidate: true, 
      class: 'btn btn-sm btn-danger',
      data: { 
        turbo_frame: "caso_ubicacionpre_#{f.index}",
        disable_with: false
      } %>
  </div>
</div>
<% end %>
